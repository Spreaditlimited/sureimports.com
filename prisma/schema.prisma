  publisherImage      String?   @db.VarChar(255)
  publisherSocialX    String?   @db.VarChar(255)
  publisherSocialLinkedin String? @db.VarChar(255)
  publisherSocialFacebook String? @db.VarChar(255)
  publisherSocialInstagram String? @db.VarChar(255)
  publisherWebsite    String?   @db.VarChar(255)
  status              String?   @db.VarChar(20) @default("active")
  createdAt           DateTime? @default(now())
  updatedAt           DateTime?
  blogs               blog[]
}


model blog_category {
