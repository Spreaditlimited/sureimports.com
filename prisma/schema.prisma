enum WalletType {
  MAIN
  SAVINGS
  CREDIT
  INVESTMENT
}

enum TransactionType {
  CREDIT
  DEBIT
  TRANSFER
}



model Account {
  id            String        @id @default(cuid())
  name          String
  pidAccount    String        @unique()
  accountName   String
  accountNumber String
  bankName      String
  first_name    String
  email         String
  customer_code String
  phone         String
  type          AccountType
  balance       Decimal?       @default(0)
  currency      String?        @default("NGN")
  color         String?       // For UI customization
  icon          String?       // Icon identifier
  isDefault     Boolean?       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  userId        String
  user          users         @relation(fields: [userId], references: [pidUser], onDelete: Cascade)

  @@index([userId])
}


enum AccountType {
  CASH
  BANK
  CREDIT_CARD
  INVESTMENT
  SAVINGS
  OTHER
}


enum PayStatus {
  SAVED
  STARTED
  COMPLETED
  CANCELLED
}


enum ProductCondition {
  BRAND_NEW
  PRE_OWNED
  REFURBISHED
  OPEN_BOX
}


enum WarrantyPeriod {
  MONTHS3
  MONTHS6
  MONTHS12
  MONTHS24
  MONTHS36
}
