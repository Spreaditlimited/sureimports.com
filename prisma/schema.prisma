model blog {
  id            Int            @id @default(autoincrement())
  pidBlog       String         @unique(map: "Blog_pidBlog_key")
  blogTitle     String         @db.VarChar(255)
  blogContent   String?        @db.LongText
  blogSlug      String?        @db.VarChar(500)
  blogPublished Boolean        @default(false)
  blogFeatured  Boolean        @default(false)
  blogImage     String?        @db.VarChar(255)
  blogBy        String?        @db.VarChar(100)
  publisherId   String?
  blogExt1      String?        @db.Text
  blogExt2      String?        @db.Text
  categoryId    String?
  xStaus        String?        @db.VarChar(50)
  createdAt     DateTime?      @default(now())
  updatedAt     DateTime?
  category      blog_category? @relation(fields: [categoryId], references: [pidCategory])
  publisher     blog_publisher? @relation(fields: [publisherId], references: [pidPublisher])

  @@index([categoryId])
  @@index([publisherId])
}


model blog_publisher {
  id                  Int       @id @default(autoincrement())
  pidPublisher        String    @unique()
